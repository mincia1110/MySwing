# MySwing Environment Variables
# Copy this file to .env and adjust values as needed

# Application
MYSWING_DEBUG=true

# Database
MYSWING_DATABASE_URL=postgresql://myswing:myswing@localhost:5432/myswing

# Redis
MYSWING_REDIS_URL=redis://localhost:6379/0

# Celery
MYSWING_CELERY_BROKER_URL=redis://localhost:6379/0
MYSWING_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# S3/MinIO
MYSWING_S3_ENDPOINT_URL=http://localhost:9000
MYSWING_S3_ACCESS_KEY=minioadmin
MYSWING_S3_SECRET_KEY=minioadmin
MYSWING_S3_BUCKET_NAME=myswing-videos
MYSWING_S3_REGION=us-east-1

# Single-swing video input policy
# MySwing is optimized for one swing per video. Recommended: 3-7s, ideal: ~5s, hard max: 10s.
MYSWING_RECOMMENDED_MIN_VIDEO_DURATION_SECONDS=3
MYSWING_RECOMMENDED_MAX_VIDEO_DURATION_SECONDS=7
MYSWING_IDEAL_VIDEO_DURATION_SECONDS=5
MYSWING_MAX_VIDEO_DURATION_SECONDS=10
